# =============================================================================
# Terraform
# =============================================================================

# Local state files — never commit; use remote state (S3 + DynamoDB) in prod
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan files may contain sensitive values (credentials, secrets)
*.tfplan
*.plan

# Provider plugins downloaded by `terraform init` — large binaries
**/.terraform/
.terraform.lock.hcl

# Crash logs generated by Terraform panics
crash.log
crash.*.log

# Variable files that may contain secrets or environment-specific overrides
# (keep dev.tfvars since it only has non-sensitive defaults for this exercise)
*.auto.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# =============================================================================
# AWS credentials — NEVER commit
# =============================================================================
.env
.env.*
*.pem
*.key
credentials

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# =============================================================================
# Editors & IDEs
# =============================================================================

# VS Code
.vscode/

# JetBrains (IntelliJ, GoLand, etc.)
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~

# =============================================================================
# Miscellaneous
# =============================================================================
*.log
*.tmp
*.bak
